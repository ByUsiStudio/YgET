{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "api/dist",
    "rootDir": "api",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": false,
    "types": ["node", "express"]
  },
  "include": ["api/**/*"],
  "exclude": ["node_modules"]
}